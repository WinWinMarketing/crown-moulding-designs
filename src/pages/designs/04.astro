---
/**
 * DESIGN 04 — Charcoal & Gold Minimal
 * Palette: white #FFFFFF, charcoal #16181D, gold #C9A227, soft grey #EEF0F2.
 * Type: Space Grotesk (display) + Inter (body).
 * Signature: very large headlines, lots of whitespace, thin 1px rules, flat
 * borderless sections separated by space, centered hero with a single large motif.
 * Photo-forward. Modern 2026 minimalism.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 04 - Charcoal & Gold Minimal" current="04" bodyClass="d04">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo" aria-label={`${meta.brandName} home`}>
        <span class="logo__mark" aria-hidden="true">
          <MouldingMotifs name="crown" class="logo__crown" />
        </span>
        <span class="logo__text">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__cta">
        <a href={meta.phoneHref} class="hdr__phone">{meta.phone}</a>
        <a href="#contact" class="btn btn--gold">Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO: centered, single large motif, enormous headline -->
  <section class="hero">
    <div class="hero__motif" aria-hidden="true">
      <MouldingMotifs name="room" class="hero__art" />
    </div>
    <div class="wrap hero__inner">
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1 class="hero__title">{hero.headline}</h1>
      <p class="hero__sub">{hero.subhead}</p>
      <div class="hero__cta">
        <a href={hero.primaryCta.href} class="btn btn--gold btn--lg">{hero.primaryCta.label}</a>
        <a href={hero.secondaryCta.href} class="btn btn--outline btn--lg">{hero.secondaryCta.label}</a>
      </div>
    </div>
    <div class="hero__rule" aria-hidden="true"></div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust">
    <div class="wrap trust__inner">
      {trustBar.map((t) => (
        <span class="trust__item">
          <span class="trust__dot" aria-hidden="true"></span>
          {t}
        </span>
      ))}
    </div>
  </div>

  <!-- STATS -->
  <section class="stats" aria-label="Company statistics">
    <div class="wrap stats__grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</div>
          <div class="stat__label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section about">
    <div class="wrap about__grid">
      <div class="about__media">
        <div class="ph">
          <MouldingMotifs name="wainscot" class="ph__art" />
          <span class="ph__cap">{about.imageCaption}</span>
        </div>
      </div>
      <div class="about__body">
        <p class="eyebrow">About Us</p>
        <h2 class="h2">{about.heading}</h2>
        <p class="body-copy">{about.body}</p>
        <ul class="tiles" role="list">
          {about.tiles.map((t) => (
            <li class="tile">
              <span class="tile__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icons[t.icon]} />
                </svg>
              </span>
              <span class="tile__txt">{t.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section services">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{services.heading}</p>
        <h2 class="h2 h2--center">Crown Moulding & Finish Carpentry</h2>
      </div>
      <div class="svc__grid">
        {services.items.map((s) => (
          <article class="svc">
            <div class="svc__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[s.icon]} />
              </svg>
            </div>
            <h3 class="svc__title">{s.title}</h3>
            <p class="svc__blurb">{s.blurb}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEE + DONE IN A DAY -->
  <section class="guarantee" aria-labelledby="guarantee-heading">
    <div class="wrap guarantee__inner">
      <div class="guarantee__rule" aria-hidden="true"></div>
      <div class="guarantee__main">
        <p class="eyebrow eyebrow--gold" id="guarantee-heading">{guarantee.heading}</p>
        <p class="guarantee__promise">{guarantee.promise}</p>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points" role="list">
        {guarantee.points.map((p) => (
          <li class="guarantee__point">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12l5 5L20 6" />
            </svg>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="work" class="section gallery">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{gallery.heading}</p>
        <h2 class="h2 h2--center">Recent Projects Across the GTA</h2>
        <p class="section__sub">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {gallery.items.map((g, i) => (
          <figure class={`gal__item${i % 5 === 0 ? " gal__item--tall" : ""}`}>
            <MouldingMotifs
              name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"}
              class="gal__art"
            />
            <figcaption class="gal__cap">
              <span class="gal__type">{g.type}</span>
              <span class="gal__city">{g.city}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section process">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{process.heading}</p>
        <h2 class="h2 h2--center">Simple, Tidy, Done Right</h2>
      </div>
      <ol class="steps" role="list">
        {process.steps.map((p) => (
          <li class="step">
            <span class="step__num" aria-label={`Step ${p.number}`}>{p.number}</span>
            <h3 class="step__title">{p.title}</h3>
            <p class="step__blurb">{p.blurb}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{reviews.heading}</p>
        <div class="reviews__rating" aria-label={`${reviews.rating.toFixed(1)} stars average`}>
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span class="rating__val">{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {reviews.items.map((r) => (
          <blockquote class="rev" cite="#">
            <span class="rev__stars" aria-label={`${r.stars} stars`} aria-hidden="true">{"★".repeat(r.stars)}</span>
            <p class="rev__quote">{r.quote}</p>
            <footer class="rev__by">{r.name} · {r.city}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section partners">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">{partners.heading}</p>
      <div class="partners__row" aria-label="Partner logos placeholder">
        {Array.from({ length: partners.count }).map(() => (
          <span class="partners__slot" aria-hidden="true">Logo</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section areas">
    <div class="wrap areas__inner">
      <div class="areas__intro">
        <p class="eyebrow">{serviceAreas.heading}</p>
        <h2 class="h2">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list" role="list">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow">Free Estimate</p>
        <h2 class="h2">{contact.heading}</h2>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone" aria-label={`Call us at ${meta.phone}`}>{contact.altContact}</a>
      </div>
      <form class="form" onsubmit="return false" aria-label="Free quote request form" novalidate>
        <div class="form__row">
          {contact.fields.slice(0, 3).map((f) => (
            <label class="field">
              <span class="field__label">{f.label}{f.required && " *"}</span>
              <input
                type={f.type}
                name={f.name}
                placeholder={f.label}
                aria-label={f.label}
                autocomplete={f.type === "tel" ? "tel" : f.type === "email" ? "email" : f.name === "name" ? "name" : undefined}
              />
            </label>
          ))}
        </div>
        <label class="field">
          <span class="field__label">Service</span>
          <select name="service" aria-label="Select a service">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span class="field__label">Message</span>
          <textarea name="message" rows={4} placeholder="Tell us about your project" aria-label="Message"></textarea>
        </label>
        <label class="field field--file">
          <span class="field__label">Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" aria-label="Upload a photo of your room" />
        </label>
        <button type="submit" class="btn btn--gold btn--lg btn--full">{contact.submitLabel}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="foot__brand-name">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#" aria-label={s}>{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">{meta.brandName} © {meta.year}. All rights reserved.</div>
  </footer>
</BaseLayout>

<style>
  /* =====================================================================
     DESIGN 04 — Charcoal & Gold Minimal
     Palette vars on body.d04 so they never leak to other designs.
  ===================================================================== */
  :global(body.d04) {
    --white: #ffffff;
    --charcoal: #16181d;
    --charcoal-soft: #2d3038;
    --gold: #c9a227;
    --gold-accessible: #8a6500;
    --gold-pale: #e8d08a;
    --grey: #eef0f2;
    --grey-mid: #c8cbcf;
    --muted: #6b7280;
    --ink: #16181d;

    margin: 0;
    background: var(--white);
    color: var(--charcoal);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
  }
  :global(body.d04) * { box-sizing: border-box; }

  /* ---- Layout helpers ---- */
  .wrap { max-width: 74rem; margin: 0 auto; padding-inline: 2rem; }

  /* ---- Typography ---- */
  .eyebrow {
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--muted);
    margin: 0 0 0.85rem;
  }
  .eyebrow--center { text-align: center; }
  .eyebrow--gold { color: var(--gold-accessible); }

  .h2 {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    font-size: clamp(1.8rem, 3.8vw, 2.75rem);
    color: var(--charcoal);
    margin: 0 0 1.25rem;
  }
  .h2--center { text-align: center; }
  .body-copy { color: var(--muted); font-size: 1rem; line-height: 1.7; margin: 0 0 1.5rem; }

  /* ---- Buttons ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    padding: 0.65rem 1.5rem;
    border-radius: 2px;
    text-decoration: none;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .btn--lg { padding: 0.85rem 2rem; font-size: 0.95rem; }
  .btn--full { width: 100%; }
  .btn--gold { background: var(--gold); color: var(--charcoal); border-color: var(--gold); }
  .btn--gold:hover { background: var(--gold-pale); border-color: var(--gold-pale); }
  .btn--outline { background: transparent; color: var(--charcoal); border-color: var(--charcoal); }
  .btn--outline:hover { background: var(--charcoal); color: var(--white); }

  /* ---- Header ---- */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--grey);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: 1.5rem;
  }
  .logo { display: flex; align-items: center; gap: 0.55rem; text-decoration: none; }
  .logo__mark { width: 1.75rem; height: 1.75rem; color: var(--gold); flex: none; }
  .logo__crown { width: 100%; height: 100%; }
  .logo__text {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--charcoal);
    font-size: 1rem;
  }
  .nav { display: flex; gap: 2rem; }
  .nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color 0.15s;
  }
  .nav a:hover { color: var(--charcoal); }
  .hdr__cta { display: flex; align-items: center; gap: 1.25rem; }
  .hdr__phone {
    color: var(--charcoal);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .hdr__phone:hover { color: var(--gold); }

  /* ---- Hero: centered, very large type, motif framed ---- */
  .hero {
    position: relative;
    padding: clamp(5rem, 12vw, 10rem) 0 clamp(4rem, 8vw, 7rem);
    text-align: center;
    overflow: hidden;
  }
  .hero__motif {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .hero__art {
    width: min(900px, 100%);
    height: auto;
    color: var(--grey-mid);
    opacity: 0.35;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 52rem;
    margin: 0 auto;
  }
  .hero__title {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.0;
    font-size: clamp(2.8rem, 7.5vw, 5.25rem);
    color: var(--charcoal);
    margin: 0 0 1.5rem;
  }
  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--muted);
    margin: 0 auto 2.5rem;
    max-width: 36rem;
    line-height: 1.7;
  }
  .hero__cta { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; }
  .hero__rule {
    position: absolute;
    bottom: 0;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: var(--grey);
  }

  /* ---- Trust bar ---- */
  .trust {
    border-bottom: 1px solid var(--grey);
    padding: 1rem 0;
  }
  .trust__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5rem 2rem;
  }
  .trust__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
  .trust__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex: none;
  }

  /* ---- Stats ---- */
  .stats {
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-bottom: 1px solid var(--grey);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }
  .stat { padding: 1.5rem 1rem; }
  .stat__num {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    letter-spacing: -0.04em;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: var(--charcoal);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat__label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ---- Sections ---- */
  .section { padding: clamp(4rem, 9vw, 7rem) 0; }
  .section__head { max-width: 38rem; margin: 0 auto 3.5rem; text-align: center; }
  .section__sub { color: var(--muted); margin: 0.75rem 0 0; font-size: 0.95rem; }

  /* ---- About ---- */
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }
  .about__media .ph { aspect-ratio: 4/5; }
  .tiles {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    border: 1px solid var(--grey);
  }
  .tile {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--grey);
    background: var(--white);
  }
  .tile__icon { width: 1.5rem; height: 1.5rem; flex: none; color: var(--gold); }
  .tile__icon svg { width: 100%; height: 100%; }
  .tile__txt { font-weight: 600; font-size: 0.85rem; color: var(--charcoal); }

  /* Placeholders */
  .ph {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--grey);
  }
  .ph__art { width: 75%; height: 75%; color: var(--grey-mid); opacity: 0.8; }
  .ph__cap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    color: var(--muted);
    background: rgba(238, 240, 242, 0.85);
    text-align: left;
    letter-spacing: 0.01em;
  }

  /* ---- Services ---- */
  .services { border-top: 1px solid var(--grey); }
  .svc__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--grey);
    border-left: 1px solid var(--grey);
  }
  .svc {
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--grey);
    border-bottom: 1px solid var(--grey);
    background: var(--white);
    transition: background 0.18s;
  }
  .svc:hover { background: var(--grey); }
  .svc__icon { width: 2rem; height: 2rem; color: var(--gold); margin-bottom: 1.25rem; }
  .svc__icon svg { width: 100%; height: 100%; }
  .svc__title {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--charcoal);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .svc__blurb { margin: 0; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }

  /* ---- Guarantee ---- */
  .guarantee {
    padding: clamp(3.5rem, 7vw, 6rem) 0;
    border-top: 1px solid var(--grey);
    border-bottom: 1px solid var(--grey);
  }
  .guarantee__inner {
