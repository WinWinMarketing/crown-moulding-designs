---
/**
 * DESIGN 09 — Warm White & Terracotta (Approachable Premium)
 * Palette: warm white #FBF7F2 background, terracotta/clay #C26B4B accent, charcoal #2A2422 text.
 * Type: Poppins (display) + DM Sans (body). Arch shapes, rounded containers, asymmetric hero.
 * Layout: arch-top image frames, rounded pills, soft warm sections, curved accent details.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 09 - Warm White & Terracotta" current="09" bodyClass="d09">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo" aria-label="Go to homepage">
        <span class="logo__mark" aria-hidden="true">
          <MouldingMotifs name="crown" class="logo__crown" />
        </span>
        <span class="logo__text">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__cta">
        <a href={meta.phoneHref} class="hdr__phone">{meta.phone}</a>
        <a href="#contact" class="btn btn--terra">Get a Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO: Asymmetric warm layout — text left, arch-framed image right -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="wrap hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="hero-heading" class="hero__title">{hero.headline}</h1>
        <p class="hero__sub">{hero.subhead}</p>
        <div class="hero__cta">
          <a href={hero.primaryCta.href} class="btn btn--terra btn--lg">{hero.primaryCta.label}</a>
          <a href={hero.secondaryCta.href} class="btn btn--outline btn--lg">{hero.secondaryCta.label}</a>
        </div>
        <div class="hero__badges">
          {trustBar.slice(0, 3).map((t) => <span class="hero__badge">{t}</span>)}
        </div>
      </div>
      <div class="hero__media" aria-hidden="true">
        <div class="arch-frame">
          <MouldingMotifs name="room" class="arch-frame__art" />
          <span class="arch-frame__cap">{hero.imageCaption}</span>
        </div>
        <div class="hero__floater hero__floater--1" aria-hidden="true">
          <MouldingMotifs name="corner" class="floater__art" />
        </div>
        <div class="hero__floater hero__floater--2" aria-hidden="true">
          <MouldingMotifs name="crown" class="floater__art" />
        </div>
      </div>
    </div>
    <div class="hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" preserveAspectRatio="none">
        <path d="M0 0 C360 60 1080 0 1440 40 L1440 60 L0 60 Z" fill="#FBF7F2" />
      </svg>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust" role="region" aria-label="Trust indicators">
    <div class="wrap trust__inner">
      {trustBar.map((t) => (
        <span class="trust__item">
          <span class="trust__check" aria-hidden="true">✓</span>
          {t}
        </span>
      ))}
    </div>
  </div>

  <!-- STATS: Soft terracotta pill counters -->
  <section class="stats" aria-label="Company statistics">
    <div class="wrap stats__grid">
      {
        stats.map((s) => (
          <div class="stat">
            <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</div>
            <div class="stat__label">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ABOUT: Arch image frame + body + rounded tiles -->
  <section id="about" class="section about" aria-labelledby="about-heading">
    <div class="wrap about__grid">
      <div class="about__media" aria-hidden="true">
        <div class="arch-frame arch-frame--tall">
          <MouldingMotifs name="wainscot" class="arch-frame__art" />
          <span class="arch-frame__cap">{about.imageCaption}</span>
        </div>
        <div class="about__accent-blob" aria-hidden="true"></div>
      </div>
      <div class="about__body">
        <p class="eyebrow">About Us</p>
        <h2 id="about-heading" class="h2">{about.heading}</h2>
        <p class="lead">{about.body}</p>
        <ul class="tiles" role="list">
          {
            about.tiles.map((t) => (
              <li class="tile">
                <span class="tile__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d={icons[t.icon]} />
                  </svg>
                </span>
                <span class="tile__txt">{t.title}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES: Rounded, soft-shadow cards with warm hover -->
  <section id="services" class="section section--warm services" aria-labelledby="services-heading">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{services.heading}</p>
        <h2 id="services-heading" class="h2 h2--center">Crown Moulding &amp; Finish Carpentry</h2>
      </div>
      <div class="svc__grid">
        {
          services.items.map((s) => (
            <article class="svc">
              <div class="svc__icon-wrap" aria-hidden="true">
                <div class="svc__icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d={icons[s.icon]} />
                  </svg>
                </div>
              </div>
              <h3 class="svc__title">{s.title}</h3>
              <p class="svc__blurb">{s.blurb}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GUARANTEE + DONE IN A DAY -->
  <section class="guarantee" aria-labelledby="guarantee-heading">
    <div class="wrap guarantee__inner">
      <div class="guarantee__main">
        <p class="eyebrow eyebrow--light">{guarantee.heading}</p>
        <p id="guarantee-heading" class="guarantee__promise">{guarantee.promise}</p>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points" role="list">
        {
          guarantee.points.map((p) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12l5 5L20 6" />
              </svg>
              {p}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- GALLERY: Arch-topped tiles with warm captions -->
  <section id="work" class="section gallery" aria-labelledby="gallery-heading">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{gallery.heading}</p>
        <h2 id="gallery-heading" class="h2 h2--center">Recent Projects Across the GTA</h2>
        <p class="section__sub">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {
          gallery.items.map((g, i) => (
            <figure class={`gal__item ${i % 5 === 0 ? "gal__item--tall" : ""}`}>
              <div class="gal__photo" aria-hidden="true">
                <MouldingMotifs
                  name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"}
                  class="gal__art"
                />
              </div>
              <figcaption class="gal__cap">
                <span class="gal__type">{g.type}</span>
                <span class="gal__city">{g.city}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PROCESS: Three rounded step cards with arched number badges -->
  <section class="section section--warm process" aria-labelledby="process-heading">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{process.heading}</p>
        <h2 id="process-heading" class="h2 h2--center">Simple, Tidy, Done Right</h2>
      </div>
      <ol class="steps" role="list">
        {
          process.steps.map((p) => (
            <li class="step">
              <span class="step__num" aria-hidden="true">{p.number}</span>
              <h3 class="step__title">{p.title}</h3>
              <p class="step__blurb">{p.blurb}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews" aria-labelledby="reviews-heading">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--center">{reviews.heading}</p>
        <div class="reviews__rating" aria-label={`${reviews.rating.toFixed(1)} star average rating`}>
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span>{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {
          reviews.items.map((r) => (
            <blockquote class="rev">
              <span class="rev__stars" aria-label={`${r.stars} out of 5 stars`}>{"★".repeat(r.stars)}</span>
              <p class="rev__quote">{r.quote}</p>
              <footer class="rev__by">{r.name} · {r.city}</footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section section--warm partners" aria-labelledby="partners-heading">
    <div class="wrap">
      <p id="partners-heading" class="eyebrow eyebrow--center">{partners.heading}</p>
      <div class="partners__row">
        {Array.from({ length: partners.count }).map(() => (
          <span class="partners__slot" aria-label="Partner logo placeholder">Logo</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section areas" aria-labelledby="areas-heading">
    <div class="wrap areas__inner">
      <div class="areas__copy">
        <p class="eyebrow">{serviceAreas.heading}</p>
        <h2 id="areas-heading" class="h2">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list" role="list">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT: Warm terracotta left panel + rounded white form -->
  <section id="contact" class="section contact" aria-labelledby="contact-heading">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow eyebrow--light">Free Estimate</p>
        <h2 id="contact-heading" class="h2 h2--light">{contact.heading}</h2>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone" aria-label="Call us">{contact.altContact}</a>
        <div class="contact__motif" aria-hidden="true">
          <MouldingMotifs name="corner" class="contact__corner" />
        </div>
      </div>
      <form class="form" onsubmit="return false" aria-label="Free estimate request form" novalidate>
        <div class="form__row">
          {
            contact.fields.slice(0, 3).map((f) => (
              <label class="field">
                <span class="field__label">{f.label}{f.required && " *"}</span>
                <input
                  type={f.type}
                  name={f.name}
                  placeholder={f.label}
                  aria-label={f.label}
                />
              </label>
            ))
          }
        </div>
        <label class="field">
          <span class="field__label">Service</span>
          <select name="service" aria-label="Select a service">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span class="field__label">Message</span>
          <textarea name="message" rows="4" placeholder="Tell us about your project" aria-label="Project message"></textarea>
        </label>
        <label class="field field--file">
          <span class="field__label">Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" aria-label="Upload a room photo" />
        </label>
        <button type="submit" class="btn btn--terra btn--lg btn--full">{contact.submitLabel}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="foot__brand-name">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#" aria-label={s}>{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">{meta.brandName} &copy; {meta.year}. All rights reserved.</div>
  </footer>
</BaseLayout>

<style>
  /* ===== PALETTE + RESET ===== */
  :global(body.d09) {
    --warm-white: #fbf7f2;
    --warm-white-2: #f5ede3;
    --terra: #c26b4b;
    --terra-deep: #a3563a;
    --terra-light: #e8a083;
    --terra-pale: #f7e8e0;
    --charcoal: #2a2422;
    --charcoal-soft: #4a3f3a;
    --muted: #7a6b63;
    --border: rgba(42, 36, 34, 0.1);
    --border-warm: rgba(194, 107, 75, 0.25);
    margin: 0;
    background: var(--warm-white);
    color: var(--charcoal);
    font-family: "DM Sans", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.65;
  }
  :global(body.d09) * { box-sizing: border-box; }

  /* ===== LAYOUT ===== */
  .wrap { max-width: 76rem; margin: 0 auto; padding-inline: 1.5rem; }

  /* ===== TYPOGRAPHY ===== */
  .eyebrow {
    font-family: "DM Sans", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.73rem;
    font-weight: 600;
    color: var(--terra);
    margin: 0 0 0.75rem;
  }
  .eyebrow--light { color: var(--terra-light); }
  .eyebrow--center { text-align: center; }

  .h2 {
    font-family: "Poppins", sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--charcoal);
    margin: 0 0 1rem;
  }
  .h2--center { text-align: center; }
  .h2--light { color: #fff; }

  .lead { font-size: 1.02rem; color: var(--muted); line-height: 1.75; }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 100px;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
  }
  .btn--lg { padding: 0.95rem 2rem; font-size: 1rem; }
  .btn--full { width: 100%; border-radius: 1rem; }
  .btn--terra {
    background: var(--terra);
    color: #fff;
  }
  .btn--terra:hover {
    background: var(--terra-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(194, 107, 75, 0.35);
  }
  .btn--terra:focus-visible {
    outline: 3px solid var(--terra-light);
    outline-offset: 3px;
  }
  .btn--outline {
    background: transparent;
    color: var(--charcoal);
    border-color: rgba(42, 36, 34, 0.3);
  }
  .btn--outline:hover {
    border-color: var(--terra);
    color: var(--terra);
    transform: translateY(-2px);
  }
  .btn--outline:focus-visible {
    outline: 3px solid var(--terra);
    outline-offset: 3px;
  }

  /* ===== HEADER ===== */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 247, 242, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
    gap: 1rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }
  .logo__mark {
    width: 2rem;
    height: 2rem;
    color: var(--terra);
    display: inline-flex;
    flex: none;
  }
  .logo__crown { width: 100%; height: 100%; }
  .logo__text {
    font-family: "Poppins", sans-serif;
    font-weight: 700;
    color: var(--charcoal);
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .nav { display: flex; gap: 1.75rem; }
  .nav a {
    color: var(--charcoal-soft);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.93rem;
    transition: color 0.15s;
  }
  .nav a:hover { color: var(--terra); }
  .nav a:focus-visible {
    outline: 2px solid var(--terra);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .hdr__cta { display: flex; align-items: center; gap: 1rem; }
  .hdr__phone {
    color: var(--charcoal);
    font-weight: 600;
    font-family: "Poppins", sans-serif;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.9rem;
  }
  .hdr__phone:hover { color: var(--terra); }

  /* ===== HERO: Asymmetric warm layout ===== */
  .hero {
    background: linear-gradient(135deg, var(--terra) 0%, var(--terra-deep) 55%, #8a4430 100%);
    color: #fff;
    overflow: hidden;
    position: relative;
    padding: clamp(3.5rem, 8vw, 6rem) 0 0;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-bottom: 3rem;
  }
  .hero__copy { position: relative; z-index: 1; }
  .hero__title {
    font-family: "Poppins", sans-serif;
    font-weight: 700;
    line-height: 1.1;
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    letter-spacing: -0.025em;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .hero__sub {
    font-size: clamp(0.98rem, 2vw, 1.12rem);
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 2rem;
    max-width: 34rem;
    line-height: 1.7;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  /* Override btn colors for hero context */
  .hero .btn--terra {
    background: #fff;
    color: var(--terra-deep);
  }
  .hero .btn--terra:hover {
    background: var(--warm-white);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }
  .hero .btn--outline {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }
  .hero .btn--outline:hover {
    border-color: #fff;
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }
  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .hero__badge {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.9);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.3rem 0.85rem;
    backdrop-filter: blur(4px);
  }

  /* Arch-top image frame */
  .arch-frame {
    position: relative;
    border-radius: 9999px 9999px 1.5rem 1.5rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3/4;
  }
  .arch-frame--tall { aspect-ratio: 4/5; }
  .arch-frame__art {
    width: 80%;
    height: 80%;
    opacity: 0.75;
    color: rgba(255, 255, 255, 0.7);
  }
  .arch-frame__cap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.65rem 0.9rem;
    font-size: 0.73rem;
    color: rgba(255, 255, 255, 0.85);
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.45));
    text-align: center;
  }

  /* Floating decorative elements */
  .hero__floater {
    position: absolute;
    pointer-events: none;
  }
  .hero__floater--1 {
    top: -1rem;
    right: -1rem;
    width: 5rem;
    height: 5rem;
    opacity: 0.25;
    color: rgba(255, 255, 255, 0.6);
  }
  .hero__floater--2 {
    bottom: 4rem;
    left: -1.5rem;
    width: 4rem;
    height: 4rem;
    opacity: 0.2;
    color: rgba(255, 255, 255, 0.6);
  }
