---
/**
 * DESIGN 07 — Sage & Walnut (Warm Organic)
 * Palette: sage green #8A9A82 accent, oat #EDEAE0 background, walnut brown #5B4636 text/dark.
 * Type: Bitter (soft serif headings) + Mulish (humanist sans body).
 * Warm and organic: generous rounded corners, soft diffuse shadows, pill buttons,
 * gentle sage/oat/walnut blocks, friendly, cozy, natural, calm.
 *
 * Self-contained: own palette + fonts + markup. Reads copy from content.ts only.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 07 - Sage & Walnut" current="07" bodyClass="d07">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:wght@500;600;700&family=Mulish:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo" aria-label="Go to top">
        <span class="logo__mark">
          <MouldingMotifs name="crown" class="logo__crown" />
        </span>
        <span class="logo__text">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__cta">
        <a href={meta.phoneHref} class="hdr__phone">{meta.phone}</a>
        <a href="#contact" class="btn btn--sage">Get a Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO: centered layout with large organic card feel -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <MouldingMotifs name="room" class="hero__room" />
    </div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="wrap hero__inner">
      <p class="eyebrow eyebrow--light">{hero.eyebrow}</p>
      <h1 class="hero__title">{hero.headline}</h1>
      <p class="hero__sub">{hero.subhead}</p>
      <div class="hero__cta">
        <a href={hero.primaryCta.href} class="btn btn--oat btn--lg btn--pill">{hero.primaryCta.label}</a>
        <a href={hero.secondaryCta.href} class="btn btn--ghost btn--lg btn--pill">{hero.secondaryCta.label}</a>
      </div>
    </div>
    <!-- Decorative leaf-like shape -->
    <div class="hero__leaf" aria-hidden="true"></div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust">
    <div class="wrap trust__inner">
      {trustBar.map((t) => <span class="trust__item">{t}</span>)}
    </div>
  </div>

  <!-- STATS -->
  <section class="stats">
    <div class="wrap stats__grid">
      {
        stats.map((s) => (
          <div class="stat">
            <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</div>
            <div class="stat__label">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ABOUT: image left, text right, organic card -->
  <section id="about" class="section about">
    <div class="wrap about__grid">
      <div class="about__media">
        <div class="ph ph--sage">
          <MouldingMotifs name="wainscot" class="ph__art" />
          <span class="ph__cap">{about.imageCaption}</span>
        </div>
        <!-- small decorative corner motif -->
        <div class="about__corner" aria-hidden="true">
          <MouldingMotifs name="corner" class="corner__art" />
        </div>
      </div>
      <div class="about__body">
        <p class="eyebrow">About Us</p>
        <h2 class="h2">{about.heading}</h2>
        <p class="lead">{about.body}</p>
        <ul class="tiles">
          {
            about.tiles.map((t) => (
              <li class="tile">
                <span class="tile__icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={icons[t.icon]} />
                  </svg>
                </span>
                <span class="tile__txt">{t.title}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES: warm card grid with soft shadows -->
  <section id="services" class="section section--walnut services">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--light">{services.heading}</p>
        <h2 class="h2 h2--light">Crown Moulding &amp; Finish Carpentry</h2>
      </div>
      <div class="svc__grid">
        {
          services.items.map((s) => (
            <article class="svc">
              <div class="svc__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={icons[s.icon]} />
                </svg>
              </div>
              <h3 class="svc__title">{s.title}</h3>
              <p class="svc__blurb">{s.blurb}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GUARANTEE + DONE IN A DAY -->
  <section class="guarantee">
    <div class="wrap guarantee__inner">
      <div class="guarantee__main">
        <p class="eyebrow">{guarantee.heading}</p>
        <p class="guarantee__promise">{guarantee.promise}</p>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points">
        {
          guarantee.points.map((p) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 6" /></svg>
              {p}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- GALLERY: soft rounded tiles with sage tones -->
  <section id="work" class="section gallery">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{gallery.heading}</p>
        <h2 class="h2">Recent Projects Across the GTA</h2>
        <p class="section__sub">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {
          gallery.items.map((g, i) => (
            <figure class={`gal__item ${i % 5 === 0 ? "gal__item--tall" : ""}`}>
              <MouldingMotifs name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"} class="gal__art" />
              <figcaption class="gal__cap">
                <span class="gal__type">{g.type}</span>
                <span class="gal__city">{g.city}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PROCESS: horizontal pill steps -->
  <section class="section section--oat process">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{process.heading}</p>
        <h2 class="h2">Simple, Tidy, Done Right</h2>
      </div>
      <ol class="steps">
        {
          process.steps.map((p) => (
            <li class="step">
              <span class="step__num">{p.number}</span>
              <h3 class="step__title">{p.title}</h3>
              <p class="step__blurb">{p.blurb}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- REVIEWS: warm card blockquotes -->
  <section class="section reviews">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{reviews.heading}</p>
        <div class="reviews__rating">
          <span class="stars" aria-label="Five stars">★★★★★</span>
          <span>{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {
          reviews.items.map((r) => (
            <blockquote class="rev">
              <span class="rev__stars" aria-label={`${r.stars} stars`}>{"★".repeat(r.stars)}</span>
              <p class="rev__quote">{r.quote}</p>
              <footer class="rev__by">{r.name} &middot; {r.city}</footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section section--oat partners">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">{partners.heading}</p>
      <div class="partners__row">
        {Array.from({ length: partners.count }).map(() => <span class="partners__slot">Logo</span>)}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section areas">
    <div class="wrap areas__inner">
      <div>
        <p class="eyebrow">{serviceAreas.heading}</p>
        <h2 class="h2">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow eyebrow--light">Free Estimate</p>
        <h2 class="h2 h2--light">{contact.heading}</h2>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone">{contact.altContact}</a>
        <div class="contact__deco" aria-hidden="true">
          <MouldingMotifs name="crown" class="contact__crown" />
        </div>
      </div>
      <form class="form" onsubmit="return false" novalidate>
        <div class="form__row">
          {
            contact.fields.slice(0, 3).map((f) => (
              <label class="field">
                <span>{f.label}{f.required && " *"}</span>
                <input
                  type={f.type}
                  name={f.name}
                  placeholder={f.label}
                  autocomplete={f.name === "phone" ? "tel" : f.name === "email" ? "email" : "name"}
                />
              </label>
            ))
          }
        </div>
        <label class="field">
          <span>Service</span>
          <select name="service">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span>Message</span>
          <textarea name="message" rows="4" placeholder="Tell us about your project"></textarea>
        </label>
        <label class="field field--file">
          <span>Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" />
        </label>
        <button type="submit" class="btn btn--sage btn--lg btn--pill btn--full">{contact.submitLabel}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="logo__text logo__text--light">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#">{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">{meta.brandName} &copy; {meta.year}. All rights reserved.</div>
  </footer>
</BaseLayout>

<style>
  /* =====================================================================
     DESIGN 07: Sage & Walnut — palette + base
     All rules are scoped to body.d07 via :global() to avoid leaking.
  ===================================================================== */
  :global(body.d07) {
    --sage: #8a9a82;
    --sage-dark: #5d6e57;
    --sage-light: #b5c4ae;
    --sage-faint: #d6dfd2;
    --oat: #edeae0;
    --oat-warm: #e5e0d3;
    --oat-deep: #d8d1c4;
    --walnut: #5b4636;
    --walnut-deep: #3e2f23;
    --walnut-mid: #7a5d47;
    --cream: #f7f5ef;
    --ink: #3a2e25;
    --muted: #7a6e63;
    --white: #ffffff;
    --radius-sm: 0.75rem;
    --radius-md: 1.25rem;
    --radius-lg: 2rem;
    --radius-pill: 99rem;
    --shadow-soft: 0 4px 24px rgba(91, 70, 54, 0.10);
    --shadow-lifted: 0 12px 40px rgba(91, 70, 54, 0.14);

    margin: 0;
    background: var(--cream);
    color: var(--ink);
    font-family: "Mulish", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.65;
  }
  :global(body.d07) * { box-sizing: border-box; }

  .wrap { max-width: 76rem; margin: 0 auto; padding-inline: 1.5rem; }

  /* ---- Typography ---- */
  .eyebrow {
    font-family: "Mulish", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--sage-dark);
    margin: 0 0 0.75rem;
  }
  .eyebrow--light { color: var(--sage-faint); }
  .eyebrow--center { text-align: center; }

  .h2 {
    font-family: "Bitter", Georgia, serif;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.18;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--walnut);
    margin: 0 0 1rem;
  }
  .h2--light { color: var(--oat); }

  .lead {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ---- Buttons (pill shape is the signature) ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Mulish", sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.8rem 1.6rem;
    border-radius: var(--radius-pill);
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: background 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
  }
  .btn--lg { padding: 1rem 2rem; font-size: 1.02rem; }
  .btn--pill { border-radius: var(--radius-pill); }
  .btn--full { width: 100%; }

  .btn--sage {
    background: var(--sage);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(138, 154, 130, 0.28);
  }
  .btn--sage:hover {
    background: var(--sage-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(138, 154, 130, 0.36);
  }
  .btn--oat {
    background: var(--oat);
    color: var(--walnut-deep);
  }
  .btn--oat:hover {
    background: var(--oat-warm);
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }
  .btn--ghost {
    background: transparent;
    color: var(--oat);
    border-color: rgba(237, 234, 224, 0.55);
  }
  .btn--ghost:hover {
    background: rgba(237, 234, 224, 0.12);
    border-color: var(--oat);
  }

  /* ---- Header ---- */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 245, 239, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--oat-deep);
    box-shadow: 0 2px 12px rgba(91, 70, 54, 0.07);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
    gap: 1rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .logo__mark {
    width: 2rem;
    height: 2rem;
    color: var(--sage);
    display: inline-flex;
    flex: none;
  }
  .logo__crown { width: 100%; height: 100%; }
  .logo__text {
    font-family: "Bitter", Georgia, serif;
    font-weight: 700;
    color: var(--walnut);
    font-size: 1.08rem;
    letter-spacing: -0.01em;
  }
  .logo__text--light {
    color: var(--oat);
    font-size: 1.2rem;
  }
  .nav { display: flex; gap: 1.75rem; }
  .nav a {
    color: var(--walnut-mid);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.15s;
  }
  .nav a:hover { color: var(--sage-dark); }
  .hdr__cta { display: flex; align-items: center; gap: 1rem; }
  .hdr__phone {
    color: var(--walnut);
    font-weight: 700;
    font-family: "Mulish", sans-serif;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.95rem;
  }
  .hdr__phone:hover { color: var(--sage-dark); }

  /* ---- Hero: centered full-bleed with walnut overlay ---- */
  .hero {
    position: relative;
    background: var(--walnut-deep);
    color: var(--white);
    overflow: hidden;
    padding: clamp(5rem, 12vw, 9rem) 0 clamp(4rem, 10vw, 7rem);
    text-align: center;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    opacity: 0.18;
  }
  .hero__room { width: 100%; height: 100%; color: var(--sage-light); }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(62, 47, 35, 0.88) 0%, rgba(91, 70, 54, 0.72) 60%, rgba(110, 127, 103, 0.55) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 54rem;
    margin: 0 auto;
  }
  .hero__title {
    font-family: "Bitter", Georgia, serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    margin: 0 0 1.25rem;
    color: var(--oat);
  }
  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.18rem);
    color: rgba(237, 234, 224, 0.85);
    margin: 0 auto 2.25rem;
    max-width: 40rem;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  /* Decorative organic leaf blob in bottom-right of hero */
  .hero__leaf {
    position: absolute;
    bottom: -4rem;
    right: -4rem;
    width: 20rem;
    height: 20rem;
    background: var(--sage);
    opacity: 0.12;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
  }

  /* ---- Trust bar ---- */
  .trust {
    background: var(--walnut);
    color: var(--oat);
  }
  .trust__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 2rem;
    padding: 1rem 1.5rem;
  }
  .trust__item {
    font-size: 0.88rem;
    font-weight: 600;
    position: relative;
    padding-left: 1.4rem;
  }
  .trust__item::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--sage-faint);
    font-weight: 800;
  }

  /* ---- Stats ---- */
  .stats {
    background: var(--oat);
    padding: clamp(2.5rem, 5vw, 3.75rem) 0;
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1rem;
    box-shadow: var(--shadow-soft);
  }
  .stat__num {
    font-family: "Bitter", Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    color: var(--sage-dark);
    line-height: 1;
  }
  .stat__label {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 600;
  }

  /* ---- Sections ---- */
  .section { padding: clamp(3.5rem, 8vw, 6rem) 0; }
  .section--walnut { background: var(--walnut); }
  .section--oat { background: var(--oat); }
  .section__head {
    max-width: 42rem;
    margin: 0 auto 2.75rem;
    text-align: center;
  }
  .section__sub { color: var(--muted); margin: 0; }

  /* ---- About ---- */
  .about { background: var(--cream); }
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about__media { position: relative; }
  .about__media .ph { aspect-ratio: 4/5; }
  .about__corner {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    width: 5rem;
    height: 5rem;
    color: var(--sage-faint);
  }
  .corner__art { width: 100%; height: 100%; }

  /* Placeholder art box */
  .ph {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--oat-warm) 0%, var(--oat-deep) 100%);
    box-shadow: var(--shadow-lifted);
  }
  .ph--sage {
    background: linear-gradient(145deg, var(--sage-faint) 0%, var(--oat-deep) 60%, var(--sage-light) 100%);
    color: var(--sage-dark);
  }
  .ph__art { width: 72%; height: 72%; opacity: 0.5; }
  .ph__cap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
