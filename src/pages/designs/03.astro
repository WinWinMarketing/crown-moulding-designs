---
/**
 * DESIGN 03 — Deep Forest & Brass (Restrained Luxury)
 * Palette: forest green #1F3A2E (dark sections), cream #F4EFE6 (light sections),
 *          brass #C7A24A accent, ink #15211B.
 * Type: Fraunces (serif display) + Inter (body).
 * Layout signature: Alternating dark-forest and cream bands, brass hairline
 * accents, split hero, upscale calm.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const autocompleteMap: Record<string, string> = {
  name: "name",
  phone: "tel",
  email: "email",
};

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 03 - Deep Forest & Brass" current="03" bodyClass="d03">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo" aria-label={`${meta.brandName} home`}>
        <span class="logo__mark" aria-hidden="true">
          <MouldingMotifs name="crown" class="logo__crown" />
        </span>
        <span class="logo__text">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__cta">
        <a href={meta.phoneHref} class="hdr__phone" aria-label={`Call us at ${meta.phone}`}>{meta.phone}</a>
        <a href="#contact" class="btn btn--brass">Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO — split layout: text left, artwork right -->
  <section class="hero" aria-label="Hero">
    <div class="hero__pane hero__pane--text">
      <div class="hero__text-inner">
        <p class="eyebrow eyebrow--brass">{hero.eyebrow}</p>
        <h1 class="hero__title">{hero.headline}</h1>
        <p class="hero__sub">{hero.subhead}</p>
        <div class="hero__cta">
          <a href={hero.primaryCta.href} class="btn btn--brass btn--lg">{hero.primaryCta.label}</a>
          <a href={hero.secondaryCta.href} class="btn btn--outline btn--lg">{hero.secondaryCta.label}</a>
        </div>
      </div>
    </div>
    <div class="hero__pane hero__pane--art" aria-hidden="true">
      <div class="hero__art-frame">
        <MouldingMotifs name="room" class="hero__room" />
        <span class="hero__art-cap">{hero.imageCaption}</span>
      </div>
      <!-- Decorative brass hairlines -->
      <span class="hero__line hero__line--h" aria-hidden="true"></span>
      <span class="hero__line hero__line--v" aria-hidden="true"></span>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust" role="region" aria-label="Trust indicators">
    <div class="wrap trust__inner">
      {trustBar.map((t) => (
        <span class="trust__item">{t}</span>
      ))}
    </div>
  </div>

  <!-- STATS — cream band -->
  <section class="stats" aria-label="Key statistics">
    <div class="wrap stats__grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>
            0{s.suffix}
          </div>
          <div class="stat__label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT — cream band -->
  <section id="about" class="section section--cream about">
    <div class="wrap about__grid">
      <div class="about__media">
        <div class="ph ph--forest">
          <MouldingMotifs name="wainscot" class="ph__art" />
          <span class="ph__cap">{about.imageCaption}</span>
        </div>
        <span class="about__line" aria-hidden="true"></span>
      </div>
      <div class="about__body">
        <p class="eyebrow eyebrow--forest">About Us</p>
        <h2 class="h2 h2--forest">{about.heading}</h2>
        <div class="brass-rule" aria-hidden="true"></div>
        <p class="lead">{about.body}</p>
        <ul class="tiles" role="list">
          {about.tiles.map((t) => (
            <li class="tile">
              <span class="tile__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icons[t.icon]} />
                </svg>
              </span>
              <span class="tile__txt">{t.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES — dark forest band -->
  <section id="services" class="section section--forest services">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--brass">{services.heading}</p>
        <h2 class="h2 h2--light">Crown Moulding &amp; Finish Carpentry</h2>
        <div class="brass-rule brass-rule--center" aria-hidden="true"></div>
      </div>
      <div class="svc__grid">
        {services.items.map((s) => (
          <article class="svc">
            <div class="svc__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[s.icon]} />
              </svg>
            </div>
            <h3 class="svc__title">{s.title}</h3>
            <p class="svc__blurb">{s.blurb}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEE — cream band -->
  <section class="guarantee section--cream">
    <div class="wrap guarantee__inner">
      <div class="guarantee__main">
        <p class="eyebrow eyebrow--forest">{guarantee.heading}</p>
        <p class="guarantee__promise">{guarantee.promise}</p>
        <div class="brass-rule" aria-hidden="true"></div>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points" role="list">
        {guarantee.points.map((p) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12l5 5L20 6" />
            </svg>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- GALLERY — dark forest band -->
  <section id="work" class="section section--forest gallery">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--brass">{gallery.heading}</p>
        <h2 class="h2 h2--light">Recent Projects Across the GTA</h2>
        <p class="section__sub section__sub--light">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {gallery.items.map((g, i) => (
          <figure class={`gal__item ${i % 5 === 0 ? "gal__item--tall" : ""}`}>
            <MouldingMotifs
              name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"}
              class="gal__art"
            />
            <figcaption class="gal__cap">
              <span class="gal__type">{g.type}</span>
              <span class="gal__city">{g.city}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS — cream band -->
  <section class="section section--cream process">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--forest">{process.heading}</p>
        <h2 class="h2 h2--forest">Simple, Tidy, Done Right</h2>
        <div class="brass-rule brass-rule--center" aria-hidden="true"></div>
      </div>
      <ol class="steps" role="list">
        {process.steps.map((p) => (
          <li class="step">
            <span class="step__num" aria-hidden="true">{p.number}</span>
            <h3 class="step__title">{p.title}</h3>
            <p class="step__blurb">{p.blurb}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- REVIEWS — dark forest band -->
  <section class="section section--forest reviews">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow eyebrow--brass">{reviews.heading}</p>
        <div class="reviews__rating">
          <span class="stars" aria-label="Five stars">★★★★★</span>
          <span class="reviews__avg">{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {reviews.items.map((r) => (
          <blockquote class="rev">
            <span class="rev__stars" aria-label={`${r.stars} stars`}>{"★".repeat(r.stars)}</span>
            <p class="rev__quote">{r.quote}</p>
            <footer class="rev__by">{r.name} · {r.city}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS — cream band -->
  <section class="section section--cream partners">
    <div class="wrap">
      <p class="eyebrow eyebrow--forest eyebrow--center">{partners.heading}</p>
      <div class="partners__row">
        {Array.from({ length: partners.count }).map(() => (
          <span class="partners__slot">Logo</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS — dark forest band -->
  <section class="section section--forest areas">
    <div class="wrap areas__inner">
      <div>
        <p class="eyebrow eyebrow--brass">{serviceAreas.heading}</p>
        <h2 class="h2 h2--light">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list" role="list">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT — cream band -->
  <section id="contact" class="section section--cream contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow eyebrow--forest">Free Estimate</p>
        <h2 class="h2 h2--forest">{contact.heading}</h2>
        <div class="brass-rule" aria-hidden="true"></div>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone" aria-label={`Call us: ${meta.phone}`}>
          {contact.altContact}
        </a>
      </div>
      <form class="form" onsubmit="return false" novalidate aria-label="Request a free quote">
        <div class="form__row">
          {contact.fields.slice(0, 3).map((f) => (
            <label class="field">
              <span>{f.label}{f.required && " *"}</span>
              <input
                type={f.type}
                name={f.name}
                placeholder={f.label}
                aria-label={f.label}
                autocomplete={autocompleteMap[f.name] ?? undefined}
              />
            </label>
          ))}
        </div>
        <label class="field">
          <span>Service</span>
          <select name="service" aria-label="Select service">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span>Message</span>
          <textarea name="message" rows={4} placeholder="Tell us about your project" aria-label="Project message"></textarea>
        </label>
        <label class="field field--file">
          <span>Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" aria-label="Upload a photo of your room" />
        </label>
        <button type="submit" class="btn btn--brass btn--lg btn--full">
          {contact.submitLabel}
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER — deep forest band -->
  <footer class="foot" role="contentinfo">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="foot__logo">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#" aria-label={s}>{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">
      {meta.brandName} &copy; {meta.year}. All rights reserved.
    </div>
  </footer>
</BaseLayout>

<style>
  /* ===== PALETTE VARIABLES ===== */
  :global(body.d03) {
    --forest: #1f3a2e;
    --forest-deep: #152a20;
    --forest-mid: #274d3c;
    --brass: #c7a24a;
    --brass-light: #dfc070;
    --cream: #f4efe6;
    --cream-dark: #ede5d8;
    --ink: #15211b;
    --muted: #44584d;
    --muted-light: rgba(244, 239, 230, 0.72);
    margin: 0;
    background: var(--cream);
    color: var(--ink);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.65;
  }
  :global(body.d03) * { box-sizing: border-box; }

  /* ===== LAYOUT ===== */
  .wrap { max-width: 78rem; margin: 0 auto; padding-inline: 1.5rem; }

  /* ===== TYPOGRAPHY ===== */
  .eyebrow {
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    font-weight: 600;
    margin: 0 0 0.85rem;
  }
  .eyebrow--brass { color: var(--brass); }
  .eyebrow--forest { color: var(--forest); }
  .eyebrow--center { text-align: center; }

  .h2 {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.15;
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    margin: 0 0 1rem;
  }
  .h2--forest { color: var(--forest); }
  .h2--light { color: var(--cream); }

  .lead {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.72;
    margin: 0 0 1.5rem;
  }

  /* Brass hairline divider */
  .brass-rule {
    width: 3rem;
    height: 2px;
    background: var(--brass);
    margin: 1rem 0 1.5rem;
    border: none;
  }
  .brass-rule--center { margin-inline: auto; }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    padding: 0.7rem 1.5rem;
    border-radius: 2px;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s ease;
  }
  .btn--lg { padding: 0.9rem 2rem; font-size: 0.95rem; }
  .btn--full { width: 100%; }
  .btn--brass {
    background: var(--brass);
    color: var(--forest-deep);
    border-color: var(--brass);
  }
  .btn--brass:hover {
    background: var(--brass-light);
    border-color: var(--brass-light);
    transform: translateY(-1px);
  }
  .btn--outline {
    background: transparent;
    color: var(--cream);
    border-color: rgba(199, 162, 74, 0.5);
  }
  .btn--outline:hover {
    border-color: var(--brass);
    color: var(--brass-light);
  }

  /* ===== HEADER ===== */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(21, 42, 32, 0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(199, 162, 74, 0.2);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
    gap: 1rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo__mark {
    width: 1.9rem;
    height: 1.9rem;
    color: var(--brass);
    display: inline-flex;
  }
  .logo__crown { width: 100%; height: 100%; }
  .logo__text {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    color: var(--cream);
    letter-spacing: 0.01em;
    font-size: 1rem;
  }
  .nav { display: flex; gap: 2rem; }
  .nav a {
    color: rgba(244, 239, 230, 0.78);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: color 0.15s;
  }
  .nav a:hover { color: var(--brass-light); }
  .hdr__cta { display: flex; align-items: center; gap: 1.25rem; }
  .hdr__phone {
    color: var(--brass-light);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .hdr__phone:hover { color: #fff; }

  /* ===== HERO — split layout ===== */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100svh - 4.25rem);
    background: var(--forest);
  }
  .hero__pane--text {
    display: flex;
    align-items: center;
    padding: clamp(3rem, 8vw, 5rem) clamp(2rem, 5vw, 4rem) clamp(3rem, 8vw, 5rem) clamp(1.5rem, 3vw, 3rem);
  }
  .hero__text-inner { max-width: 32rem; }
  .hero__title {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.08;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--cream);
    margin: 0 0 1.25rem;
  }
  .hero__sub {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--muted-light);
    margin: 0 0 2.25rem;
    line-height: 1.75;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  .hero__pane--art {
    position: relative;
    overflow: hidden;
    background: var(--forest-mid);
    border-left: 1px solid rgba(199, 162, 74, 0.18);
  }
  .hero__art-frame {
    position: absolute;
    inset: 2.5rem;
    border: 1px solid rgba(199, 162, 74, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(199, 162, 74, 0.35);
  }
  .hero__room { width: 85%; height: 85%; }
  .hero__art-cap {
    position: absolute;
    bottom: 0.75rem;
    left: 0.9rem;
    right: 0.9rem;
    font-size: 0.72rem;
    color: rgba(244, 239, 230, 0.6);
    letter-spacing: 0.03em;
  }
  /* Decorative brass hairlines */
  .hero__line {
    position: absolute;
    background: var(--brass);
    opacity: 0.4;
  }
  .hero__line--h {
    top: 2rem;
    left: 0;
    right: 0;
    height: 1px;
  }
  .hero__line--v {
    top: 0;
    bottom: 0;
    left: 2rem;
    width: 1px;
  }

  /* ===== TRUST BAR ===== */
  .trust { background: var(--forest-deep); }
  .trust__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 2rem;
    padding: 1rem 1.5rem;
  }
  .trust__item {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(244, 239, 230, 0.85);
    position: relative;
    padding: 0.4rem 0 0.4rem 1.4rem;
    letter-spacing: 0.04em;
  }
  .trust__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0.65rem;
    height: 0.65rem;
    border: 1.5px solid var(--brass);
    border-radius: 50%;
    background: var(--brass);
    opacity: 0.7;
  }

  /* ===== STATS — cream band ===== */
  .stats {
    background: var(--cream-dark);
    padding: clamp(2.5rem, 5vw, 3.5rem) 0;
    border-bottom: 1px solid rgba(31, 58, 46, 0.12);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat {
    padding: 1.5rem 1rem;
    position: relative;
  }
  .stat + .stat::before {
    content: "";
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 1px;
    background: rgba(199, 162, 74, 0.3);
  }
  .stat__num {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3rem);
    color: var(--forest);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat__label {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ===== SECTIONS ===== */
  .section { padding: clamp(4rem, 9vw, 7rem) 0; }
  .section--cream { background: var(--cream); }
  .section--forest { background: var(--forest); }

  .section__head {
    max-width: 44rem;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .section__sub { color: var(--muted); margin: 0.75rem 0 0; font-size: 1rem; }
  .section__sub--light { color: var(--muted-light); }

