---
/**
 * DESIGN 01 — Deck Navy & Gold (Classic Trust)
 * Palette: navy #15243F, gold #C8923D, off-white #F7F5F0, ink #1B1B1B.
 * Type: Sora (display) + Inter (body). Solid bands, classic contractor trust.
 * Matches the approved WinWin deck. This is the reference exemplar for the set.
 *
 * Self-contained: own palette + fonts + markup. Reads copy from content.ts only.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 01 — Deck Navy & Gold" current="01" bodyClass="d01">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo">
        <span class="logo__mark"><MouldingMotifs name="crown" class="logo__crown" /></span>
        <span class="logo__text">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__cta">
        <a href={meta.phoneHref} class="hdr__phone">{meta.phone}</a>
        <a href="#contact" class="btn btn--gold">Get a Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <MouldingMotifs name="room" class="hero__room" />
    </div>
    <div class="wrap hero__inner">
      <p class="eyebrow eyebrow--light">{hero.eyebrow}</p>
      <h1 class="hero__title">{hero.headline}</h1>
      <p class="hero__sub">{hero.subhead}</p>
      <div class="hero__cta">
        <a href={hero.primaryCta.href} class="btn btn--gold btn--lg">{hero.primaryCta.label}</a>
        <a href={hero.secondaryCta.href} class="btn btn--ghost btn--lg">{hero.secondaryCta.label}</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust">
    <div class="wrap trust__inner">
      {trustBar.map((t) => <span class="trust__item">{t}</span>)}
    </div>
  </div>

  <!-- STATS -->
  <section class="stats">
    <div class="wrap stats__grid">
      {
        stats.map((s) => (
          <div class="stat">
            <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</div>
            <div class="stat__label">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section about">
    <div class="wrap about__grid">
      <div class="about__media">
        <div class="ph ph--navy">
          <MouldingMotifs name="wainscot" class="ph__art" />
          <span class="ph__cap">{about.imageCaption}</span>
        </div>
      </div>
      <div class="about__body">
        <p class="eyebrow">About Us</p>
        <h2 class="h2">{about.heading}</h2>
        <p class="lead">{about.body}</p>
        <ul class="tiles">
          {
            about.tiles.map((t) => (
              <li class="tile">
                <span class="tile__icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d={icons[t.icon]} />
                  </svg>
                </span>
                <span class="tile__txt">{t.title}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section section--alt services">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{services.heading}</p>
        <h2 class="h2">Crown Moulding & Finish Carpentry</h2>
      </div>
      <div class="svc__grid">
        {
          services.items.map((s) => (
            <article class="svc">
              <div class="svc__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icons[s.icon]} />
                </svg>
              </div>
              <h3 class="svc__title">{s.title}</h3>
              <p class="svc__blurb">{s.blurb}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GUARANTEE + DONE IN A DAY -->
  <section class="guarantee">
    <div class="wrap guarantee__inner">
      <div class="guarantee__main">
        <p class="eyebrow eyebrow--light">{guarantee.heading}</p>
        <p class="guarantee__promise">{guarantee.promise}</p>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points">
        {
          guarantee.points.map((p) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6" /></svg>
              {p}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="work" class="section gallery">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{gallery.heading}</p>
        <h2 class="h2">Recent Projects Across the GTA</h2>
        <p class="section__sub">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {
          gallery.items.map((g, i) => (
            <figure class={`gal__item ${i % 5 === 0 ? "gal__item--tall" : ""}`}>
              <MouldingMotifs name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"} class="gal__art" />
              <figcaption class="gal__cap">
                <span class="gal__type">{g.type}</span>
                <span class="gal__city">{g.city}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section section--alt process">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{process.heading}</p>
        <h2 class="h2">Simple, Tidy, Done Right</h2>
      </div>
      <ol class="steps">
        {
          process.steps.map((p) => (
            <li class="step">
              <span class="step__num">{p.number}</span>
              <h3 class="step__title">{p.title}</h3>
              <p class="step__blurb">{p.blurb}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{reviews.heading}</p>
        <div class="reviews__rating">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span>{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {
          reviews.items.map((r) => (
            <blockquote class="rev">
              <span class="rev__stars" aria-hidden="true">{"★".repeat(r.stars)}</span>
              <p class="rev__quote">{r.quote}</p>
              <footer class="rev__by">{r.name} · {r.city}</footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section section--alt partners">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">{partners.heading}</p>
      <div class="partners__row">
        {Array.from({ length: partners.count }).map(() => <span class="partners__slot">Logo</span>)}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section areas">
    <div class="wrap areas__inner">
      <div>
        <p class="eyebrow">{serviceAreas.heading}</p>
        <h2 class="h2">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow eyebrow--light">Free Estimate</p>
        <h2 class="h2 h2--light">{contact.heading}</h2>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone">{contact.altContact}</a>
      </div>
      <form class="form" onsubmit="return false">
        <div class="form__row">
          {
            contact.fields.slice(0, 3).map((f) => (
              <label class="field">
                <span>{f.label}{f.required && " *"}</span>
                <input
                  type={f.type}
                  name={f.name}
                  placeholder={f.label}
                  autocomplete={f.name === "name" ? "name" : f.name === "phone" ? "tel" : f.name === "email" ? "email" : undefined}
                />
              </label>
            ))
          }
        </div>
        <label class="field">
          <span>Service</span>
          <select name="service" autocomplete="off">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span>Message</span>
          <textarea name="message" rows="4" placeholder="Tell us about your project"></textarea>
        </label>
        <label class="field field--file">
          <span>Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" />
        </label>
        <button type="submit" class="btn btn--gold btn--lg btn--full">{contact.submitLabel}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="logo__text logo__text--light">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#">{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">{meta.brandName} © {meta.year}. All rights reserved.</div>
  </footer>
</BaseLayout>

<style>
  :global(body.d01) {
    --navy: #15243f;
    --navy-deep: #0f1b30;
    --gold: #c8923d;
    --gold-soft: #e0b86a;
    --cream: #f7f5f0;
    --ink: #1b1b1b;
    --muted: #5d6473;
    margin: 0;
    background: var(--cream);
    color: var(--ink);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.6;
  }
  :global(body.d01) * { box-sizing: border-box; }

  .wrap { max-width: 76rem; margin: 0 auto; padding-inline: 1.5rem; }

  /* Typography helpers */
  .eyebrow {
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    font-weight: 700;
    color: #8B5E10;
    margin: 0 0 0.75rem;
  }
  .eyebrow--light { color: var(--gold-soft); }
  .eyebrow--center { text-align: center; }
  .h2 {
    font-family: "Sora", sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.12;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--navy);
    margin: 0 0 1rem;
  }
  .h2--light { color: #fff; }
  .lead { font-size: 1.05rem; color: var(--muted); }

  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-family: "Sora", sans-serif; font-weight: 600; font-size: 0.95rem;
    padding: 0.75rem 1.4rem; border-radius: 0.5rem; text-decoration: none;
    cursor: pointer; border: 2px solid transparent; transition: all 0.16s ease;
  }
  .btn--lg { padding: 0.95rem 1.8rem; font-size: 1rem; }
  .btn--full { width: 100%; }
  .btn--gold { background: var(--gold); color: var(--navy-deep); }
  .btn--gold:hover { background: var(--gold-soft); transform: translateY(-2px); }
  .btn--ghost { background: transparent; color: #fff; border-color: rgba(255,255,255,0.5); }
  .btn--ghost:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  /* Header */
  .hdr {
    position: sticky; top: 0; z-index: 50;
    background: rgba(21,36,63,0.96); backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .hdr__inner { display: flex; align-items: center; justify-content: space-between; height: 4.5rem; gap: 1rem; }
  .logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .logo__mark { width: 2rem; height: 2rem; color: var(--gold); display: inline-flex; }
  .logo__crown { width: 100%; height: 100%; }
  .logo__text { font-family: "Sora", sans-serif; font-weight: 800; color: #fff; letter-spacing: -0.01em; font-size: 1.05rem; }
  .logo__text--light { color: #fff; font-size: 1.25rem; }
  .nav { display: flex; gap: 1.75rem; }
  .nav a { color: rgba(255,255,255,0.85); text-decoration: none; font-weight: 500; font-size: 0.95rem; transition: color 0.15s; }
  .nav a:hover { color: var(--gold-soft); }
  .hdr__cta { display: flex; align-items: center; gap: 1rem; }
  .hdr__phone { color: #fff; font-weight: 700; font-family: "Sora", sans-serif; text-decoration: none; white-space: nowrap; }
  .hdr__phone:hover { color: var(--gold-soft); }

  /* Hero */
  .hero { position: relative; background: var(--navy); color: #fff; overflow: hidden; padding: clamp(4rem, 10vw, 8rem) 0; }
  .hero__bg { position: absolute; inset: 0; opacity: 0.5; }
  .hero__room { width: 100%; height: 100%; color: var(--gold-soft); }
  .hero::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(105deg, var(--navy-deep) 30%, rgba(15,27,48,0.7) 60%, rgba(15,27,48,0.35));
  }
  .hero__inner { position: relative; z-index: 2; max-width: 42rem; }
  .hero__title {
    font-family: "Sora", sans-serif; font-weight: 800; letter-spacing: -0.025em;
    line-height: 1.04; font-size: clamp(2.2rem, 6vw, 4rem); margin: 0 0 1.25rem;
  }
  .hero__sub { font-size: clamp(1rem, 2.2vw, 1.2rem); color: rgba(255,255,255,0.82); margin: 0 0 2rem; max-width: 36rem; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* Trust bar */
  .trust { background: var(--navy-deep); color: #fff; }
  .trust__inner { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 2.25rem; padding: 1rem 1.5rem; }
  .trust__item { font-size: 0.9rem; font-weight: 600; position: relative; padding-left: 1.4rem; }
  .trust__item::before {
    content: "✓"; position: absolute; left: 0; color: var(--gold); font-weight: 800;
  }

  /* Stats */
  .stats { background: var(--cream); padding: clamp(2.5rem, 5vw, 3.5rem) 0; }
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; text-align: center; }
  .stat__num { font-family: "Sora", sans-serif; font-weight: 800; font-size: clamp(1.8rem, 4vw, 2.75rem); color: var(--navy); line-height: 1; }
  .stat__label { margin-top: 0.5rem; font-size: 0.85rem; color: var(--muted); font-weight: 500; }

  /* Sections */
  .section { padding: clamp(3.5rem, 8vw, 6rem) 0; }
  .section--alt { background: #fff; }
  .section__head { max-width: 42rem; margin: 0 auto 2.75rem; text-align: center; }
  .section__sub { color: var(--muted); margin: 0; }

  /* About */
  .about__grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .about__media .ph { aspect-ratio: 4/5; }
  .tiles { list-style: none; margin: 1.75rem 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .tile { display: flex; align-items: center; gap: 0.75rem; background: var(--cream); border: 1px solid rgba(21,36,63,0.08); border-radius: 0.6rem; padding: 0.85rem 1rem; }
  .tile__icon { width: 2rem; height: 2rem; flex: none; color: var(--gold); }
  .tile__icon svg { width: 100%; height: 100%; }
  .tile__txt { font-weight: 600; font-size: 0.9rem; color: var(--navy); }

  /* Placeholders */
  .ph { position: relative; border-radius: 0.85rem; overflow: hidden; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--navy), var(--navy-deep)); }
  .ph--navy { color: var(--gold-soft); }
  .ph__art { width: 78%; height: 78%; opacity: 0.7; }
  .ph__cap { position: absolute; bottom: 0; left: 0; right: 0; padding: 0.6rem 0.9rem; font-size: 0.75rem; color: rgba(255,255,255,0.8); background: linear-gradient(transparent, rgba(0,0,0,0.55)); text-align: left; }

  /* Services */
  .svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .svc { background: var(--cream); border: 1px solid rgba(21,36,63,0.08); border-radius: 0.85rem; padding: 1.75rem; transition: all 0.18s ease; }
  .svc:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: 0 16px 32px rgba(21,36,63,0.1); }
  .svc__icon { width: 3rem; height: 3rem; color: var(--gold); margin-bottom: 1rem; }
  .svc__icon svg { width: 100%; height: 100%; }
  .svc__title { font-family: "Sora", sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--navy); margin: 0 0 0.5rem; }
  .svc__blurb { margin: 0; color: var(--muted); font-size: 0.95rem; }

  /* Guarantee */
  .guarantee { background: var(--navy); color: #fff; padding: clamp(3rem, 6vw, 4.5rem) 0; }
  .guarantee__inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2.5rem; align-items: center; }
  .guarantee__promise { font-family: "Sora", sans-serif; font-size: clamp(1.3rem, 3vw, 1.9rem); font-weight: 700; line-height: 1.25; margin: 0 0 1rem; }
  .guarantee__speed { color: rgba(255,255,255,0.78); margin: 0; }
  .guarantee__points { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .guarantee__points li { display: flex; align-items: center; gap: 0.75rem; font-weight: 600; }
  .guarantee__points svg { width: 1.4rem; height: 1.4rem; flex: none; color: var(--gold); }

  /* Gallery */
  .gal__grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 200px; gap: 1rem; }
  .gal__item { position: relative; border-radius: 0.75rem; overflow: hidden; background: linear-gradient(135deg, var(--navy), var(--navy-deep)); display: flex; align-items: center; justify-content: center; color: var(--gold-soft); }
  .gal__item--tall { grid-row: span 2; }
  .gal__art { width: 70%; height: 70%; opacity: 0.6; }
  .gal__cap { position: absolute; bottom: 0; left: 0; right: 0; display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 0.9rem; background: linear-gradient(transparent, rgba(0,0,0,0.7)); }
  .gal__type { color: #fff; font-weight: 600; font-size: 0.85rem; }
  .gal__city { color: var(--gold-soft); font-size: 0.78rem; }

  /* Process */
  .steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; counter-reset: step; }
  .step { text-align: center; padding: 1.5rem; }
  .step__num { display: inline-flex; align-items: center; justify-content: center; width: 3.25rem; height: 3.25rem; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: "Sora", sans-serif; font-weight: 800; font-size: 1.4rem; margin-bottom: 1rem; }
  .step__title { font-family: "Sora", sans-serif; font-size: 1.15rem; color: var(--navy); margin: 0 0 0.4rem; }
  .step__blurb { color: var(--muted); margin: 0; font-size: 0.95rem; }

  /* Reviews */
  .reviews__rating { display: flex; align-items: center; justify-content: center; gap: 0.6rem; color: var(--muted); font-weight: 600; }
  .stars, .rev__stars { color: #8B5E10; letter-spacing: 0.1em; }
  .rev__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .rev { margin: 0; background: var(--cream); border: 1px solid rgba(21,36,63,0.08); border-left: 4px solid var(--gold); border-radius: 0.6rem; padding: 1.75rem; }
  .rev__quote { font-size: 1rem; color: var(--ink); margin: 0.75rem 0; }
  .rev__by { font-weight: 700; color: var(--navy); font-size: 0.9rem; }

  /* Partners */
  .partners__row { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; }
