---
/**
 * DESIGN 12: Ivory & Royal Blue (Crisp Professional)
 * Palette: ivory #FBFAF7 bg, cobalt #2348C6 accent, charcoal #16181D text.
 * Type: Manrope only (modern single-family, all weights).
 * Layout signature: crisp ivory base, bold cobalt accents + buttons, tight rounded
 * cards, confident grid, energetic but trustworthy. Hero is a horizontal split
 * with the motif on the right, copy hard-left. Friendly modern professional.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import MouldingMotifs from "../../components/MouldingMotifs.astro";
import {
  meta, nav, hero, trustBar, stats, about, services, guarantee,
  gallery, process, reviews, partners, serviceAreas, contact, footer,
} from "../../data/content";

const icons: Record<string, string> = {
  hammer: "M14 6l4 4M3 21l9-9M14 6l3-3 4 4-3 3M8 12l8 8",
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z",
  sparkle: "M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z",
  compass: "M12 22a10 10 0 100-20 10 10 0 000 20zM16 8l-2.5 5.5L8 16l2.5-5.5z",
  crown: "M3 18l2-9 5 5 2-7 2 7 5-5 2 9z",
  panel: "M4 4h16v16H4zM4 10h16M10 4v16",
  grid: "M4 4h16v16H4zM4 12h16M12 4v16",
  ruler: "M3 8h18v8H3zM7 8v4M11 8v4M15 8v4M19 8v4",
  wall: "M3 5h18v14H3zM3 12h18M9 5v7M15 12v7",
  door: "M5 21V4a1 1 0 011-1h9a1 1 0 011 1v17M5 21h14M13 12h.01",
};
---

<BaseLayout title="Design 12 - Ivory & Royal Blue" current="12" bodyClass="d12">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- HEADER -->
  <header id="home" class="hdr">
    <div class="wrap hdr__inner">
      <a href="#home" class="logo" aria-label={`${meta.brandName} homepage`}>
        <span class="logo__icon"><MouldingMotifs name="crown" class="logo__crown" /></span>
        <span class="logo__name">{meta.brandName}</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="hdr__actions">
        <a href={meta.phoneHref} class="hdr__phone">{meta.phone}</a>
        <a href="#contact" class="btn btn--cobalt">Free Quote</a>
      </div>
    </div>
  </header>

  <!-- HERO: horizontal split, copy left, motif panel right -->
  <section class="hero">
    <div class="wrap hero__inner">
      <div class="hero__copy">
        <span class="chip">{hero.eyebrow}</span>
        <h1 class="hero__h1">{hero.headline}</h1>
        <p class="hero__sub">{hero.subhead}</p>
        <div class="hero__cta">
          <a href={hero.primaryCta.href} class="btn btn--cobalt btn--lg">{hero.primaryCta.label}</a>
          <a href={hero.secondaryCta.href} class="btn btn--outline btn--lg">{hero.secondaryCta.label}</a>
        </div>
      </div>
      <div class="hero__visual" aria-hidden="true">
        <div class="hero__motif-wrap">
          <MouldingMotifs name="room" class="hero__room" />
          <div class="hero__badge">
            <span class="hero__badge-num">15+</span>
            <span class="hero__badge-lbl">Years of Craftsmanship</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust" role="list" aria-label="Trust signals">
    <div class="wrap trust__inner">
      {trustBar.map((t) => (
        <span class="trust__item" role="listitem">
          <svg class="trust__check" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          {t}
        </span>
      ))}
    </div>
  </div>

  <!-- STATS -->
  <section class="stats" aria-label="Company statistics">
    <div class="wrap stats__grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat__num" data-count={s.value} data-suffix={s.suffix}>0{s.suffix}</div>
          <div class="stat__label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section about">
    <div class="wrap about__grid">
      <div class="about__media">
        <div class="ph">
          <MouldingMotifs name="wainscot" class="ph__art" />
          <span class="ph__cap">{about.imageCaption}</span>
        </div>
        <!-- decorative accent block -->
        <div class="about__deco" aria-hidden="true"></div>
      </div>
      <div class="about__body">
        <p class="eyebrow">About Us</p>
        <h2 class="h2">{about.heading}</h2>
        <p class="lead">{about.body}</p>
        <ul class="tiles">
          {about.tiles.map((t) => (
            <li class="tile">
              <span class="tile__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icons[t.icon]} />
                </svg>
              </span>
              <span class="tile__txt">{t.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section section--blue-bg services">
    <div class="wrap">
      <div class="section__head section__head--light">
        <p class="eyebrow eyebrow--light">{services.heading}</p>
        <h2 class="h2 h2--light">Crown Moulding &amp; Finish Carpentry</h2>
      </div>
      <div class="svc__grid">
        {services.items.map((s) => (
          <article class="svc">
            <div class="svc__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[s.icon]} />
              </svg>
            </div>
            <h3 class="svc__title">{s.title}</h3>
            <p class="svc__blurb">{s.blurb}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEE + DONE IN A DAY -->
  <section class="guarantee">
    <div class="wrap guarantee__inner">
      <div class="guarantee__main">
        <p class="eyebrow eyebrow--light">{guarantee.heading}</p>
        <p class="guarantee__promise">{guarantee.promise}</p>
        <p class="guarantee__speed">{guarantee.speed}</p>
      </div>
      <ul class="guarantee__points">
        {guarantee.points.map((p) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 6" /></svg>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="work" class="section gallery">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{gallery.heading}</p>
        <h2 class="h2">Recent Projects Across the GTA</h2>
        <p class="section__sub">{gallery.subheading}</p>
      </div>
      <div class="gal__grid">
        {gallery.items.map((g, i) => (
          <figure class={`gal__item${i % 5 === 0 ? " gal__item--tall" : ""}`}>
            <MouldingMotifs
              name={i % 3 === 0 ? "coffered" : i % 3 === 1 ? "wainscot" : "room"}
              class="gal__art"
            />
            <figcaption class="gal__cap">
              <span class="gal__type">{g.type}</span>
              <span class="gal__city">{g.city}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section section--ivory process">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{process.heading}</p>
        <h2 class="h2">Simple, Tidy, Done Right</h2>
      </div>
      <ol class="steps">
        {process.steps.map((p) => (
          <li class="step">
            <span class="step__num" aria-hidden="true">{p.number}</span>
            <h3 class="step__title">{p.title}</h3>
            <p class="step__blurb">{p.blurb}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">{reviews.heading}</p>
        <div class="reviews__rating">
          <span class="stars" aria-label="5 stars">★★★★★</span>
          <span>{reviews.rating.toFixed(1)} average rating</span>
        </div>
      </div>
      <div class="rev__grid">
        {reviews.items.map((r) => (
          <blockquote class="rev">
            <span class="rev__stars" aria-label={`${r.stars} stars`}>{"★".repeat(r.stars)}</span>
            <p class="rev__quote">{r.quote}</p>
            <footer class="rev__by">{r.name} &middot; {r.city}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section section--ivory partners">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">{partners.heading}</p>
      <div class="partners__row">
        {Array.from({ length: partners.count }).map((_, i) => (
          <span class="partners__slot" aria-label={`Partner logo ${i + 1}`}>Logo</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section areas">
    <div class="wrap areas__inner">
      <div>
        <p class="eyebrow">{serviceAreas.heading}</p>
        <h2 class="h2">{serviceAreas.intro}</h2>
      </div>
      <ul class="areas__list" aria-label="Cities served">
        {serviceAreas.cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <p class="eyebrow eyebrow--light">Free Estimate</p>
        <h2 class="h2 h2--light">{contact.heading}</h2>
        <p class="contact__sub">{contact.subcopy}</p>
        <a href={meta.phoneHref} class="contact__phone" aria-label="Call us">{contact.altContact}</a>
        <div class="contact__motif" aria-hidden="true">
          <MouldingMotifs name="corner" class="contact__corner" />
        </div>
      </div>
      <form class="form" onsubmit="return false" aria-label="Free estimate request form">
        <div class="form__row">
          {contact.fields.slice(0, 3).map((f) => (
            <label class="field">
              <span>{f.label}{f.required && " *"}</span>
              <input
                type={f.type}
                name={f.name}
                placeholder={f.label}
                aria-required={f.required ? "true" : "false"}
                autocomplete={f.name === "name" ? "name" : f.name === "phone" ? "tel" : f.name === "email" ? "email" : undefined}
              />
            </label>
          ))}
        </div>
        <label class="field">
          <span>Service</span>
          <select name="service">
            {(contact.fields[3].options ?? []).map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field">
          <span>Message</span>
          <textarea name="message" rows={4} placeholder="Tell us about your project"></textarea>
        </label>
        <label class="field field--file">
          <span>Photo of your room (optional)</span>
          <input type="file" name="photo" accept="image/*" />
        </label>
        <button type="submit" class="btn btn--cobalt btn--lg btn--full">{contact.submitLabel}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <div class="foot__brand">
        <span class="foot__brand-name">{meta.brandName}</span>
        <p>{meta.tagline} in the {meta.serviceRegion}.</p>
      </div>
      <div class="foot__col">
        <h4>Contact</h4>
        <a href={meta.phoneHref}>{meta.phone}</a>
        <a href={`mailto:${meta.email}`}>{meta.email}</a>
        <p>{footer.hours}</p>
      </div>
      <div class="foot__col">
        <h4>Service Areas</h4>
        <p>{serviceAreas.cities.join(", ")}</p>
      </div>
      <div class="foot__col">
        <h4>More</h4>
        {footer.badges.map((b) => <span class="foot__badge">{b}</span>)}
        <div class="foot__social">
          {footer.socials.map((s) => <a href="#" aria-label={s}>{s}</a>)}
        </div>
      </div>
    </div>
    <div class="wrap foot__legal">{meta.brandName} &copy; {meta.year}. All rights reserved.</div>
  </footer>
</BaseLayout>

<style>
  /* =====================================================================
     DESIGN 12: IVORY & ROYAL BLUE
     Palette vars scoped to body.d12 so nothing leaks to other designs.
  ===================================================================== */
  :global(body.d12) {
    --ivory: #fbfaf7;
    --ivory-deep: #f2f0ea;
    --cobalt: #2348c6;
    --cobalt-deep: #1a3aa8;
    --cobalt-soft: #3d61d9;
    --cobalt-pale: #e8edf9;
    --charcoal: #16181d;
    --ink: #2c3040;
    --muted: #5c6278;
    --border: rgba(35, 72, 198, 0.12);
    --white: #ffffff;
    margin: 0;
    background: var(--ivory);
    color: var(--ink);
    font-family: "Manrope", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.6;
  }
  :global(body.d12) * { box-sizing: border-box; }

  .wrap { max-width: 76rem; margin: 0 auto; padding-inline: 1.5rem; }

  /* ---- Typography helpers ------------------------------------------ */
  .eyebrow {
    font-family: "Manrope", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--cobalt);
    margin: 0 0 0.7rem;
  }
  .eyebrow--light { color: rgba(255, 255, 255, 0.7); }
  .eyebrow--center { text-align: center; }

  .h2 {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    font-size: clamp(1.55rem, 3.4vw, 2.35rem);
    color: var(--charcoal);
    margin: 0 0 1rem;
  }
  .h2--light { color: var(--white); }

  .lead { font-size: 1rem; color: var(--muted); line-height: 1.7; margin: 0 0 1rem; }

  /* ---- Buttons -------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Manrope", sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    padding: 0.7rem 1.35rem;
    border-radius: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .btn--lg { padding: 0.9rem 1.75rem; font-size: 0.95rem; }
  .btn--full { width: 100%; }
  .btn--cobalt {
    background: var(--cobalt);
    color: var(--white);
    box-shadow: 0 2px 8px rgba(35, 72, 198, 0.28);
  }
  .btn--cobalt:hover {
    background: var(--cobalt-deep);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(35, 72, 198, 0.35);
  }
  .btn--outline {
    background: transparent;
    color: var(--cobalt);
    border-color: var(--cobalt);
  }
  .btn--outline:hover { background: var(--cobalt-pale); }

  /* ---- Header --------------------------------------------------------- */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 250, 247, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 1px 0 var(--border);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
    gap: 1rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }
  .logo__icon {
    width: 1.9rem;
    height: 1.9rem;
    color: var(--cobalt);
    display: inline-flex;
    flex-shrink: 0;
  }
  .logo__crown { width: 100%; height: 100%; }
  .logo__name {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: var(--charcoal);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .nav { display: flex; gap: 1.5rem; }
  .nav a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: color 0.14s;
  }
  .nav a:hover { color: var(--cobalt); }
  .hdr__actions { display: flex; align-items: center; gap: 1rem; }
  .hdr__phone {
    color: var(--charcoal);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .hdr__phone:hover { color: var(--cobalt); }

  /* ---- Hero (horizontal split) --------------------------------------- */
  .hero {
    background: var(--ivory);
    padding: clamp(3rem, 8vw, 6.5rem) 0;
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .chip {
    display: inline-block;
    background: var(--cobalt-pale);
    color: var(--cobalt);
    font-family: "Manrope", sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border-radius: 2rem;
    margin-bottom: 1.1rem;
  }
  .hero__h1 {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.06;
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    color: var(--charcoal);
    margin: 0 0 1.25rem;
  }
  .hero__sub {
    font-size: clamp(0.95rem, 1.8vw, 1.08rem);
    color: var(--muted);
    margin: 0 0 2rem;
    max-width: 34rem;
    line-height: 1.7;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.85rem; }
  .hero__visual { position: relative; }
  .hero__motif-wrap {
    position: relative;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--cobalt) 0%, var(--cobalt-deep) 100%);
    border-radius: 1.25rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 24px 60px rgba(35, 72, 198, 0.22);
  }
  .hero__room {
    width: 85%;
    height: 85%;
    color: rgba(255, 255, 255, 0.35);
  }
  .hero__badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: var(--white);
    border-radius: 0.75rem;
    padding: 0.75rem 1.1rem;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .hero__badge-num {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--cobalt);
  }
  .hero__badge-lbl {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
  }

  /* ---- Trust bar ----------------------------------------------------- */
  .trust {
    background: var(--cobalt);
    color: var(--white);
  }
  .trust__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 2rem;
    padding: 0.9rem 1.5rem;
  }
  .trust__item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .trust__check {
    width: 1rem;
    height: 1rem;
    color: rgba(255, 255, 255, 0.8);
    flex-shrink: 0;
  }

  /* ---- Stats ---------------------------------------------------------- */
  .stats {
    background: var(--ivory-deep);
    padding: clamp(2.5rem, 5vw, 3.75rem) 0;
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat { padding: 1rem; }
  .stat__num {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    color: var(--cobalt);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat__label {
    margin-top: 0.45rem;
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  /* ---- Sections ------------------------------------------------------- */
  .section { padding: clamp(3.5rem, 8vw, 6rem) 0; }
  .section--blue-bg { background: var(--cobalt); }
  .section--ivory { background: var(--ivory-deep); }
  .section__head { max-width: 42rem; margin: 0 auto 2.75rem; text-align: center; }
  .section__head--light { color: var(--white); }
  .section__sub { color: var(--muted); margin: 0.5rem 0 0; font-size: 0.95rem; }

  /* ---- About ---------------------------------------------------------- */
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: center;
  }
  .about__media { position: relative; }
  .ph {
    position: relative;
    aspect-ratio: 4/5;
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, var(--cobalt) 0%, var(--cobalt-deep) 100%);
    box-shadow: 0 16px 48px rgba(35, 72, 198, 0.2);
  }
  .ph__art {
    width: 78%;
    height: 78%;
    color: rgba(255, 255, 255, 0.28);
  }
  .ph__cap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.6rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 600;
