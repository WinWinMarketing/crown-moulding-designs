  .rev__quote { font-family: var(--font-display); font-size: 1.25rem; line-height: 1.4; color: var(--text); margin: 0.75rem 0; font-style: italic; }
  .rev__by { font-weight: 700; color: var(--text); font-size: 0.9rem; }

  /* Partners */
  .partners .container { text-align: center; }
  .partners__row { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; }
  .partners__slot { display: grid; place-items: center; width: 9rem; height: 3.75rem; border: 1px dashed var(--border-strong); border-radius: var(--radius); color: var(--text-faint); font-size: 0.85rem; }

  /* Areas */
  .areas__grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2.5rem; align-items: center; }
  .areas__list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
  .areas__list li { padding: 0.65rem 0.95rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); font-weight: 600; color: var(--text); }

  /* Contact */
  .contact__grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 5vw, 4rem); }
  .contact__phone { font-family: var(--font-display); font-weight: 600; font-size: 1.3rem; color: var(--accent-strong); text-decoration: none; }
  .form { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: clamp(1.5rem, 3vw, 2.25rem); }
  .form__row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .field span { font-size: 0.8rem; font-weight: 600; color: var(--text); }
  .field input, .field select, .field textarea { border: 1px solid var(--border-strong); border-radius: var(--radius); padding: 0.7rem 0.85rem; font: inherit; color: var(--text); background: var(--bg); width: 100%; }
  .field input:focus, .field select:focus, .field textarea:focus { outline: 2px solid var(--accent); border-color: var(--accent); }

  /* Footer */
  .foot { background: var(--bg-mute); border-top: 1px solid var(--border); padding: 3.5rem 0 0; }
