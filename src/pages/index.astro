  .foot__brand p { margin: 0.75rem 0 0; font-size: 0.9rem; color: var(--text-muted); }
  .foot__col h4 { font-family: var(--font-display); color: var(--text); font-size: 1.05rem; margin: 0 0 0.9rem; font-weight: 600; }
  .foot__col a, .foot__col p { display: block; color: var(--text-muted); text-decoration: none; font-size: 0.9rem; margin: 0 0 0.5rem; }
  .foot__col a:hover { color: var(--accent-strong); }
  .foot__badge { display: inline-block; border: 1px solid var(--accent); color: var(--accent-strong); border-radius: var(--radius); padding: 0.25rem 0.6rem; font-size: 0.8rem; margin-bottom: 0.75rem; }
