---
import BaseLayout from "../layouts/BaseLayout.astro";
import MouldingMotifs from "../components/MouldingMotifs.astro";
import { designs, meta } from "../data/content";

// Base path so card links work under the GitHub Pages subpath (no trailing slash).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Crown Moulding Website — Choose Your Design"
  description="12 homepage design options for the crown moulding website. Click through and pick your favourite."
  bodyClass="cm-chooser"
>
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <header class="chooser-hero">
    <div class="chooser-hero__inner">
      <p class="chooser-hero__eyebrow">WinWin Marketing · Design Options</p>
      <h1 class="chooser-hero__title">
        Choose the look for your<br /><span>Crown Moulding</span> website
      </h1>
      <p class="chooser-hero__sub">
        Below are {designs.length} complete homepage designs. They all use the same content and layout flow,
        so the only thing that changes is the style. Click any design to see the full page, then use the bar
        at the bottom to flip between them. Tell us your favourite and we'll build it out in full.
      </p>
      <p class="chooser-hero__note">
        Brand name, phone, photos, and reviews are placeholders for now.
      </p>
    </div>
    <div class="chooser-hero__motif" aria-hidden="true">
      <MouldingMotifs name="crown" class="chooser-hero__crown" />
    </div>
  </header>

  <main class="chooser-grid-wrap">
    <ul class="chooser-grid">
      {
        designs.map((d, i) => (
          <li class="card">
            <a class="card__link" href={`${base}/designs/${d.id}/`}>
              <div
                class="card__preview"
                style={`--bg:${d.swatches[0]};--accent:${d.swatches[1]};--ink:${d.swatches[2]}`}
              >
                <span class="card__num">{String(i + 1).padStart(2, "0")}</span>
                <div class="card__mock">
                  <span class="card__mock-bar" />
                  <span class="card__mock-h" />
                  <span class="card__mock-h card__mock-h--short" />
                  <span class="card__mock-btn" />
                  <div class="card__mock-tiles">
                    <span /><span /><span />
                  </div>
                </div>
                <div class="card__swatches">
                  {d.swatches.map((s) => (
                    <span class="card__swatch" style={`background:${s}`} />
                  ))}
                </div>
              </div>
              <div class="card__body">
                <h2 class="card__name">{d.name}</h2>
                <p class="card__note">{d.note}</p>
                <span class="card__cta">View design <span aria-hidden="true">→</span></span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <footer class="chooser-foot">
    <p>{meta.brandName} · Crown Moulding website design options · Prepared by WinWin Marketing · {meta.year}</p>
  </footer>
</BaseLayout>

<style>
  :global(body.cm-chooser) {
    margin: 0;
    background: #0d0f14;
    color: #e9ebef;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
  }

  .chooser-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 8vw, 6rem) 1.5rem clamp(2rem, 5vw, 3.5rem);
    background:
      radial-gradient(120% 140% at 85% -10%, rgba(200, 146, 61, 0.18), transparent 55%),
      linear-gradient(180deg, #11151d, #0d0f14);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .chooser-hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .chooser-hero__eyebrow {
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    font-weight: 600;
    color: #c8923d;
  }
  .chooser-hero__title {
    margin: 0 0 1.25rem;
    font-family: "Sora", sans-serif;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-size: clamp(2rem, 5.5vw, 3.5rem);
  }
  .chooser-hero__title span {
    color: #c8923d;
  }
  .chooser-hero__sub {
    margin: 0 0 0.75rem;
    max-width: 46rem;
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    line-height: 1.6;
    color: #b9bec8;
  }
  .chooser-hero__note {
    margin: 0;
    font-size: 0.85rem;
    color: #6f7682;
    font-style: italic;
  }
  .chooser-hero__motif {
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: clamp(10rem, 30vw, 22rem);
    color: rgba(200, 146, 61, 0.14);
    z-index: 0;
  }
  .chooser-hero__crown {
    width: 100%;
    height: auto;
  }

  .chooser-grid-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 3.5rem) 1.5rem 5rem;
  }
  .chooser-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1.5rem;
  }

  .card {
    border-radius: 1rem;
    overflow: hidden;
    background: #161922;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(200, 146, 61, 0.55);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.4);
  }
  .card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card__preview {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--bg);
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }
  .card__num {
    position: absolute;
    top: 0.6rem;
    right: 0.85rem;
    font-family: "Sora", sans-serif;
    font-weight: 800;
    font-size: 2.25rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.55;
  }
  /* tiny abstract homepage mock so each card hints at a real layout */
  .card__mock {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    width: 78%;
  }
  .card__mock-bar {
    height: 6px;
    width: 55%;
    border-radius: 3px;
    background: var(--accent);
  }
  .card__mock-h {
    height: 10px;
    width: 90%;
    border-radius: 3px;
    background: var(--ink);
    opacity: 0.85;
  }
  .card__mock-h--short {
    width: 60%;
    opacity: 0.55;
  }
  .card__mock-btn {
    margin-top: 0.15rem;
    height: 12px;
    width: 38%;
    border-radius: 6px;
    background: var(--accent);
  }
  .card__mock-tiles {
    margin-top: 0.55rem;
    display: flex;
    gap: 0.35rem;
  }
  .card__mock-tiles span {
    height: 16px;
    flex: 1;
    border-radius: 4px;
    background: var(--ink);
    opacity: 0.18;
  }
  .card__swatches {
    position: absolute;
    bottom: 0.7rem;
    left: 1.1rem;
    display: flex;
    gap: 0.3rem;
  }
  .card__swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .card__body {
    padding: 1rem 1.15rem 1.25rem;
  }
  .card__name {
    margin: 0 0 0.3rem;
    font-family: "Sora", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
  }
  .card__note {
    margin: 0 0 0.85rem;
    font-size: 0.85rem;
    color: #9aa1ac;
    line-height: 1.45;
  }
  .card__cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: #c8923d;
  }
  .card:hover .card__cta span {
    margin-left: 0.15rem;
  }

  .chooser-foot {
    text-align: center;
    padding: 2rem 1.5rem 3rem;
    color: #5e6571;
    font-size: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .chooser-foot p {
    margin: 0;
  }
</style>
